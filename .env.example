# ====================================================================
# cn_memory 配置文件示例 (B方案 - 2026-06-04)
# ====================================================================
# 复制此文件为 .env 并填入你的真实配置
#   cp .env.example .env
#   vim .env
# 所有变量都是可选的，但生产环境必须配置 embedding API key
# ====================================================================

# --- Embedding API（向量化）---
# 端点：embedding 服务地址
CN_MEMORY_EMBEDDING_ENDPOINT=https://api.minimaxi.com/v1/embeddings
# 模型：embedding 模型名（与端点匹配）
CN_MEMORY_EMBEDDING_MODEL=embo-01
# 鉴权：embedding API key（如果与 LLM 共享一个 key，可省略，自动 fallback）
# 优先级: CN_MEMORY_EMBEDDING_API_KEY > CN_MEMORY_LLM_API_KEY > 空
CN_MEMORY_EMBEDDING_API_KEY=

# --- LLM（记忆提取/反思）---
CN_MEMORY_LLM_BASE_URL=https://api.minimaxi.com/v1
CN_MEMORY_LLM_MODEL=MiniMax-Text-01
CN_MEMORY_LLM_API_KEY=
# 可选: 从 dotenv 文件名加载（默认是 LLM_API_KEY 等）
# CN_MEMORY_LLM_KEY_ENV=MINIMAX_API_KEY
CN_MEMORY_LLM_TIMEOUT=8

# --- 内存管理 ---
CN_MEMORY_HERMES_HOME=/vol1/@apphome/trim.openclaw/data/home/.hermes

# --- 安全提示 ---
# 1. 永远不要把 .env 提交到 git
# 2. 生产环境建议用 secrets manager (e.g. /vol1/1000/AI/secrets/)
# 3. 最小权限: embedding key 只需要 embeddings 权限
